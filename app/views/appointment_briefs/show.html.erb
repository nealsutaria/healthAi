<% content_for :title, @appointment_brief.title %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6">
      <%= link_to "← Back to Copilot",
            copilot_path,
            class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <div class="mb-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700 mb-4">
          <span>🩺</span>
          <span>Appointment Prep Agent</span>
        </div>

        <h1 class="text-4xl font-bold tracking-tight text-gray-950">
          <%= @appointment_brief.title %>
        </h1>

        <p class="mt-3 text-sm text-gray-500">
          Generated <%= @appointment_brief.created_at.strftime("%b %d, %Y %l:%M %p") %>
        </p>
      </div>

      <div class="rounded-2xl border border-blue-100 bg-blue-50 px-5 py-4 mb-8">
        <p class="text-sm text-blue-800">
          This brief is for appointment preparation only. It does not provide medical diagnosis or treatment.
        </p>
      </div>

      <div class="prose max-w-none text-gray-700 whitespace-pre-line leading-7">
        <%= @appointment_brief.content %>
      </div>
    </div>

  </div>
</div>
