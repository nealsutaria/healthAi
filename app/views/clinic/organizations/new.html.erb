<% content_for :title, "Create Clinic" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6">
      <%= link_to "← Back to Clinics",
            clinic_organizations_path,
            class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <div class="mb-8">
        <p class="text-sm font-semibold text-indigo-700">Clinic Portal</p>

        <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-950">
          Create a Clinic
        </h1>

        <p class="mt-3 text-gray-600">
          Create a clinic workspace for business-facing AI agents like prior authorization prep.
        </p>
      </div>

      <%= form_with model: [:clinic, @organization], local: true do |form| %>
        <% if @organization.errors.any? %>
          <div class="mb-6 rounded-2xl border border-red-100 bg-red-50 px-5 py-4">
            <p class="text-sm font-semibold text-red-700">
              Please fix the errors below.
            </p>
          </div>
        <% end %>

        <div>
          <%= form.label :name, "Clinic name", class: "block text-sm font-semibold text-gray-700 mb-2" %>

          <%= form.text_field :name,
                placeholder: "e.g. Austin Ortho Clinic",
                class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <div class="mt-6">
          <%= form.submit "Create Clinic",
                class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-500 transition cursor-pointer" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
