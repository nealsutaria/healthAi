<% content_for :title, "Invite Staff" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6">
      <%= link_to "← Back to Members",
            clinic_organization_memberships_path(@organization),
            class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700 mb-4">
        <span>✉️</span>
        <span>Clinic Invitation</span>
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-gray-950">
        Invite Staff
      </h1>

      <p class="mt-4 text-gray-600 leading-7">
        Invite a team member to join <%= @organization.name %>. They will receive access based on the role you choose.
      </p>

      <% if @clinic_invitation.errors.any? %>
        <div class="mt-6 rounded-2xl bg-red-50 border border-red-100 p-4">
          <p class="font-semibold text-red-700">
            Please fix the following:
          </p>

          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% @clinic_invitation.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: [:clinic, @organization, @clinic_invitation],
            local: true,
            class: "mt-8 space-y-6" do |form| %>

        <div>
          <%= form.label :email, "Staff Email", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.email_field :email,
                placeholder: "staff@clinic.com",
                class: "w-full rounded-2xl border border-gray-200 px-4 py-3 text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= form.label :role, "Role", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.select :role,
                [
                  ["Provider", "provider"],
                  ["Billing Staff", "billing_staff"],
                  ["Staff", "staff"]
                ],
                { prompt: "Choose a role" },
                class: "w-full rounded-2xl border border-gray-200 px-4 py-3 text-gray-900 focus:border-indigo-500 focus:ring-indigo-500" %>

          <p class="mt-2 text-sm text-gray-500">
            Owners can manage members. Providers and billing staff can use clinic agents.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <%= form.submit "Create Invitation",
                class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-500 transition" %>

          <%= link_to "Cancel",
                clinic_organization_memberships_path(@organization),
                class: "inline-flex items-center justify-center rounded-xl bg-gray-100 px-5 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-200 transition" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
