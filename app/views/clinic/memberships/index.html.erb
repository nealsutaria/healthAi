<% content_for :title, "Manage Members" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <%= link_to "← Back to #{@organization.name}",
            clinic_organization_path(@organization),
            class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>

      <%= link_to "Invite Staff",
            new_clinic_organization_clinic_invitation_path(@organization),
            class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition" %>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 mb-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700 mb-4">
        <span>👥</span>
        <span>Clinic Team</span>
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-gray-950">
        Manage Members
      </h1>

      <p class="mt-4 text-gray-600 leading-7">
        Add clinic staff, view active members, and manage pending invitations for this workspace.
      </p>
    </div>

    <!-- Active Members -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-sm font-semibold text-indigo-700">Active Access</p>
          <h2 class="mt-1 text-2xl font-bold text-gray-950">
            Members
          </h2>
        </div>

        <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">
          <%= pluralize(@memberships.count, "member") %>
        </span>
      </div>

      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <% @memberships.each do |membership| %>
          <div class="p-5 border-b border-gray-100 last:border-b-0 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <p class="font-semibold text-gray-950">
                <%= membership.user.email %>
              </p>

              <p class="mt-1 text-sm text-gray-500">
                Role: <%= membership.role.humanize %>
              </p>
            </div>

            <% if membership.user != current_user %>
              <%= button_to "Remove",
                    clinic_organization_membership_path(@organization, membership),
                    method: :delete,
                    form: { data: { turbo_confirm: "Remove this member from the clinic?" } },
                    class: "inline-flex items-center justify-center rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-600 hover:bg-red-100 transition" %>
            <% else %>
              <span class="inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-500">
                You
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Pending Invitations -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-sm font-semibold text-indigo-700">Pending Access</p>
          <h2 class="mt-1 text-2xl font-bold text-gray-950">
            Invitations
          </h2>
        </div>

        <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">
          <%= pluralize(@clinic_invitations.where(accepted_at: nil).count, "pending invite") %>
        </span>
      </div>

      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <% pending_invitations = @clinic_invitations.select { |invite| invite.accepted_at.nil? } %>

        <% if pending_invitations.any? %>
          <% pending_invitations.each do |invite| %>
            <div class="p-5 border-b border-gray-100 last:border-b-0 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <p class="font-semibold text-gray-950">
                  <%= invite.email %>
                </p>

                <p class="mt-1 text-sm text-gray-500">
                  Role: <%= invite.role.humanize %> · Invited <%= time_ago_in_words(invite.created_at) %> ago
                </p>
              </div>

              <%= button_to "Delete Invite",
                    clinic_organization_clinic_invitation_path(@organization, invite),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this invitation?" } },
                    class: "inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200 transition" %>
            </div>
          <% end %>
        <% else %>
          <div class="p-6">
            <p class="text-gray-500">
              No pending invitations.
            </p>
          </div>
        <% end %>
      </div>
    </section>

  </div>
</div>
