<% content_for :title, "AI Health Copilot" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Header -->
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 mb-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-3 py-1 text-sm font-medium text-indigo-700 mb-4">
            <span>🧠</span>
            <span>AI Health Copilot</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-950">
            Your health history, understood.
          </h1>

          <p class="mt-4 max-w-2xl text-base text-gray-600">
            MHBright reviews your saved records and surfaces important observations,
            follow-ups, and patterns so you can feel more prepared for your next visit.
          </p>
        </div>

          <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 min-w-[220px]">
            <p class="text-sm text-gray-500">Copilot Status</p>
            <p class="mt-1 text-2xl font-bold text-gray-900">Active</p>
            <p class="mt-2 text-sm text-gray-500">
              <%= @insights.count %> insights found
            </p>
          </div>
      </div>
    </div>

    <!-- Safety Note -->
    <div class="mb-8 rounded-2xl border border-blue-100 bg-blue-50 px-5 py-4">
      <p class="text-sm text-blue-800">
        MHBright does not provide medical diagnosis or treatment. Use these insights to prepare for conversations with your healthcare provider.
      </p>
    </div>

    <!-- Summary + Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
      <div class="lg:col-span-2 bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
        <p class="text-sm font-semibold text-indigo-700">Copilot Summary</p>

        <% if @insights.any? %>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">
            Your Copilot found <%= pluralize(@insights.count, "important observation") %>.
          </h2>
          <p class="mt-3 text-gray-600 leading-7">
            These insights are generated from your saved health records and are meant to help you remember important details, identify patterns, and prepare for future doctor visits.
          </p>

          <p class="mt-4 text-sm text-gray-500">
            Last analyzed:
            <span class="font-semibold text-gray-700">
              <%= @last_analyzed_at ? @last_analyzed_at.strftime("%b %d, %Y %l:%M %p") : "Not yet" %>
            </span>
          </p>
        <% else %>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">
            Add records to unlock your Copilot.
          </h2>
          <p class="mt-3 text-gray-600 leading-7">
            Once you add health records, your Copilot will begin creating useful observations from your history.
          </p>
        <% end %>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-1 gap-4">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-5">
          <p class="text-sm text-gray-500">Health Records</p>
          <p class="mt-2 text-3xl font-bold text-gray-950"><%= @records_count %></p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-5">
          <p class="text-sm text-gray-500">AI Insights</p>
          <p class="mt-2 text-3xl font-bold text-gray-950"><%= @insights_count %></p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-5">
          <p class="text-sm text-gray-500">Doctor Questions</p>
          <p class="mt-2 text-3xl font-bold text-gray-950"><%= @doctor_questions_count %></p>
        </div>
      </div>
    </div>

    <!-- Key Insights -->
    <section>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
        <div>
          <p class="text-sm font-semibold text-indigo-700">Personalized Review</p>
          <h2 class="mt-1 text-3xl font-bold tracking-tight text-gray-950">
            Key Health Insights
          </h2>
        </div>

        <p class="text-sm text-gray-500">
          Generated from your saved health history
        </p>
      </div>

      <% if @insights.any? %>
        <div class="grid gap-5 md:grid-cols-2">
          <% @insights.each do |insight| %>
            <div class="group bg-white rounded-3xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
              <div class="flex items-start justify-between gap-4">
                <div class="h-11 w-11 rounded-2xl bg-indigo-50 flex items-center justify-center text-xl">
                  ✨
                </div>

                <% if insight.severity.present? %>
                  <span class="text-xs px-3 py-1 rounded-full bg-gray-100 text-gray-600 capitalize">
                    <%= insight.severity %>
                  </span>
                <% end %>
              </div>

              <h3 class="mt-5 text-xl font-bold text-gray-950">
                <%= insight.title %>
              </h3>

              <p class="mt-3 text-gray-600 leading-7 whitespace-pre-line">
                <%= insight.body %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
          <div class="mx-auto h-14 w-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-2xl">
            📝
          </div>

          <h3 class="mt-5 text-xl font-bold text-gray-950">
            No insights yet
          </h3>

          <p class="mt-2 text-gray-500">
            Add a health record and your Copilot will begin generating insights.
          </p>

          <div class="mt-6">
            <%= link_to "Add Health Record", new_record_path, class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" %>
          </div>
        </div>
      <% end %>
    </section>

    <section class="mt-12">
      <br>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
        <div>
          <p class="text-sm font-semibold text-indigo-700">Doctor Prep</p>
          <h2 class="mt-1 text-3xl font-bold tracking-tight text-gray-950">
            Questions for Your Doctor
          </h2>
        </div>

        <p class="text-sm text-gray-500">
          Generated from your health history
        </p>
      </div>

      <% if @doctor_questions.any? %>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 divide-y divide-gray-100">
          <% @doctor_questions.each do |doctor_question| %>
            <div class="p-6 flex gap-4">
              <div class="h-10 w-10 rounded-2xl bg-indigo-50 flex items-center justify-center text-lg flex-shrink-0">
                ❓
              </div>

              <p class="text-gray-700 leading-7">
                <%= doctor_question.question %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
          <div class="mx-auto h-14 w-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-2xl">
            ❓
          </div>

          <h3 class="mt-5 text-xl font-bold text-gray-950">
            No doctor questions yet
          </h3>

          <p class="mt-2 text-gray-500">
            Add more health records and your Copilot will prepare questions for your next visit.
          </p>
        </div>
      <% end %>
    </section>


    <!-- Recent Health Timeline -->
    <br>
    <section class="mt-12">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
        <div>
          <p class="text-sm font-semibold text-indigo-700">Recent Activity</p>
          <h2 class="mt-1 text-3xl font-bold tracking-tight text-gray-950">
            Recent Health Timeline
          </h2>
        </div>

        <p class="text-sm text-gray-500">
          Your latest saved records
        </p>
      </div>

      <% if @recent_records.any? %>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
          <% @recent_records.each do |record| %>
            <div class="p-6 border-b border-gray-100 last:border-b-0">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-indigo-700">
                    <%= record.date.strftime("%B %d, %Y") %>
                  </p>

                  <h3 class="mt-1 text-xl font-bold text-gray-950">
                    <%= record.reason %>
                  </h3>

                  <div class="mt-3 space-y-1 text-sm text-gray-600">
                    <% if record.prescription? && record.prescription_name.present? %>
                      <p>
                        <span class="font-semibold text-gray-700">Prescription:</span>
                        <%= record.prescription_name %>
                      </p>
                    <% end %>

                    <% if record.test_done? && record.test_type.present? %>
                      <p>
                        <span class="font-semibold text-gray-700">Test:</span>
                        <%= record.test_type %>
                      </p>
                    <% end %>

                    <% if record.comments.present? %>
                      <p class="line-clamp-2">
                        <span class="font-semibold text-gray-700">Notes:</span>
                        <%= record.comments %>
                      </p>
                    <% end %>
                  </div>
                </div>

                <div class="flex-shrink-0">
                  <%= link_to "View Record", record_path(record), class: "inline-flex items-center justify-center rounded-xl bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200 transition" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
          <div class="mx-auto h-14 w-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-2xl">
            📋
          </div>

          <h3 class="mt-5 text-xl font-bold text-gray-950">
            No records yet
          </h3>

          <p class="mt-2 text-gray-500">
            Add health records to build your health timeline.
          </p>
        </div>
      <% end %>
    </section>

  </div>
</div>
