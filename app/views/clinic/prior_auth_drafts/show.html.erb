<% content_for :title, "Prior Auth Packet" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <%= link_to "← Back to Prior Auth Drafts",
        clinic_organization_prior_auth_drafts_path(@organization),
        class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to "Edit Details",
          edit_clinic_organization_prior_auth_draft_path(@organization, @prior_auth_draft),
          class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition" %>

        <%= button_to "Delete Draft",
          clinic_organization_prior_auth_draft_path(@organization, @prior_auth_draft),
          method: :delete,
          form: { data: { turbo_confirm: "Delete this prior auth draft?" } },
          class: "inline-flex items-center justify-center rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 transition" %>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 mb-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <div>
          <p class="text-sm font-semibold text-indigo-700"><%= @organization.name %></p>

          <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-950">
            Prior Authorization Prep Packet
          </h1>

          <p class="mt-3 text-gray-600">
            Generated <%= @prior_auth_draft.created_at.strftime("%b %d, %Y %l:%M %p") %>
          </p>
        </div>

        <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600 capitalize">
          <%= @prior_auth_draft.status %>
        </span>
      </div>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-2xl bg-gray-50 border border-gray-100 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase">Patient</p>
          <p class="mt-1 font-semibold text-gray-950"><%= @prior_auth_draft.patient_name %></p>
        </div>

        <div class="rounded-2xl bg-gray-50 border border-gray-100 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase">Insurance</p>
          <p class="mt-1 font-semibold text-gray-950"><%= @prior_auth_draft.insurance_payer %></p>
        </div>

        <div class="rounded-2xl bg-gray-50 border border-gray-100 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase">Condition</p>
          <p class="mt-1 font-semibold text-gray-950"><%= @prior_auth_draft.condition %></p>
        </div>

        <div class="rounded-2xl bg-gray-50 border border-gray-100 p-4">
          <p class="text-xs font-semibold text-gray-500 uppercase">Requested Service</p>
          <p class="mt-1 font-semibold text-gray-950"><%= @prior_auth_draft.requested_service %></p>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-blue-100 bg-blue-50 px-5 py-4 mb-8">
      <p class="text-sm text-blue-800">
        This packet is a preparation draft only. It is not an insurance submission, medical decision, or guarantee of approval.
      </p>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <div class="prose max-w-none text-gray-700 whitespace-pre-line leading-7">
        <%= @prior_auth_draft.content %>
      </div>
    </div>

  </div>
</div>
