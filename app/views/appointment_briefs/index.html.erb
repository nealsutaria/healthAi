<% content_for :title, "Appointment Briefs" %>

<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6 flex items-center justify-between gap-4">
      <div>
        <%= link_to "← Back to Copilot",
              copilot_path,
              class: "text-sm font-semibold text-indigo-700 hover:text-indigo-600" %>

        <h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-950">
          Appointment Briefs
        </h1>

        <p class="mt-2 text-gray-600">
          View and manage your saved appointment preparation briefs.
        </p>
      </div>
    </div>

    <% if @appointment_briefs.any? %>
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 divide-y divide-gray-100">
        <% @appointment_briefs.each do |brief| %>
          <div class="p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-indigo-700">
                <%= brief.created_at.strftime("%b %d, %Y %l:%M %p") %>
              </p>

              <h2 class="mt-1 text-xl font-bold text-gray-950">
                <%= brief.title %>
              </h2>

              <p class="mt-2 text-sm text-gray-500 line-clamp-2">
                <%= brief.content.to_s.truncate(180) %>
              </p>
            </div>

            <div class="flex items-center gap-3 flex-shrink-0">
              <%= link_to "View",
                    appointment_brief_path(brief),
                    class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition" %>

              <%= button_to "Delete",
                    appointment_brief_path(brief),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this appointment brief?" } },
                    class: "inline-flex items-center justify-center rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 transition" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
        <div class="mx-auto h-14 w-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-2xl">
          🩺
        </div>

        <h2 class="mt-5 text-xl font-bold text-gray-950">
          No appointment briefs yet
        </h2>

        <p class="mt-2 text-gray-500">
          Generate one from your AI Health Copilot dashboard.
        </p>

        <div class="mt-6">
          <%= link_to "Go to Copilot",
                copilot_path,
                class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-500 transition" %>
        </div>
      </div>
    <% end %>

  </div>
</div>
